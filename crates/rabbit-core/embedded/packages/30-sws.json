{
  "id": "sws",
  "display_name": "SWS Extension",
  "display_name_key": "package-sws",
  "display_description_key": "package-sws-description",
  "package_kind": "user_plugin_binary",
  "required": false,
  "recommended": true,
  "supported_platforms": [
    "windows",
    "macos"
  ],
  "supported_architectures": [
    "x86",
    "x64",
    "arm64",
    "universal"
  ],
  "version": {
    "html": {
      "url": "https://sws-extension.org/",
      "pattern": "Latest stable version:[\\s\\S]*?v([0-9.]+)[\\s\\S]*?#([0-9]+)",
      "format": "{1}.{2}"
    }
  },
  "artifact_provider": "sws_download_page",
  "detectors": [
    "rabbit_receipt",
    "user_plugin_file",
    "reapack_registry",
    "file_version_metadata",
    {
      "binary_version_string": {
        "pattern": "([0-9]+(?:\\.[0-9]+){2,}) #[0-9a-fA-F]{6,}",
        "label": "sws-binary-version-string",
        "note": "Version came from a best-effort scan for SWS's embedded `version #commit` string."
      }
    }
  ],
  "install_steps": [
    "run_upstream_installer",
    "copy_user_plugin_binary"
  ],
  "uninstall_steps": [
    "remove_user_plugin_binary"
  ],
  "backup_policy": "backup_overwritten_files",
  "user_plugin_prefixes": [
    "reaper_sws"
  ],
  "user_plugin_suffixes": {
    "windows": [
      ".dll"
    ],
    "macos": [
      ".dylib"
    ]
  }
}
