{
  "id": "osara",
  "display_name": "OSARA",
  "display_name_key": "package-osara",
  "display_description_key": "package-osara-description",
  "package_kind": "user_plugin_binary",
  "required": false,
  "recommended": true,
  "supported_platforms": [
    "windows",
    "macos"
  ],
  "supported_architectures": [
    "x86",
    "x64",
    "arm64",
    "arm64-ec",
    "universal"
  ],
  "version": {
    "json": {
      "url": "https://osara.reaperaccessibility.com/snapshots/update.json",
      "pointer": "/version"
    }
  },
  "artifact_provider": "osara_snapshots",
  "detectors": [
    "rabbit_receipt",
    "user_plugin_file",
    {
      "uninstall_display_version": {
        "display_name": "OSARA"
      }
    },
    "file_version_metadata",
    "reapack_registry",
    {
      "binary_version_string": {
        "pattern": "(20[0-9]{2}(?:\\.[0-9]+){2,})",
        "label": "osara-binary-version-string",
        "note": "Version came from a best-effort scan for OSARA's embedded version string."
      }
    }
  ],
  "install_steps": [
    "run_upstream_installer",
    "copy_user_plugin_binary"
  ],
  "uninstall_steps": [
    "remove_user_plugin_binary"
  ],
  "backup_policy": "backup_overwritten_files",
  "user_plugin_prefixes": [
    "reaper_osara"
  ],
  "user_plugin_suffixes": {
    "windows": [
      ".dll"
    ],
    "macos": [
      ".dylib"
    ]
  }
}
