{
  "id": "reaper",
  "display_name": "REAPER",
  "display_name_key": "package-reaper",
  "display_description_key": "package-reaper-description",
  "package_kind": "reaper_app",
  "required": false,
  "recommended": true,
  "supported_platforms": [
    "windows",
    "macos"
  ],
  "supported_architectures": [
    "x86",
    "x64",
    "arm64",
    "arm64-ec",
    "universal"
  ],
  "version": {
    "html": {
      "url": "https://www.reaper.fm/download.php",
      "pattern": "Version ([0-9][0-9.]*)"
    }
  },
  "detectors": [
    "file_version_metadata"
  ],
  "install_steps": [
    "run_upstream_installer"
  ],
  "uninstall_steps": [],
  "backup_policy": "none",
  "user_plugin_prefixes": [],
  "user_plugin_suffixes": {
    "windows": [],
    "macos": []
  },
  "http_artifact": {
    "targets": [
      {
        "platform": "windows",
        "match_arches": [
          "x86"
        ],
        "report_arch": "x86",
        "artifact_kind": "installer",
        "source": {
          "scrape_href": {
            "page_url": "https://www.reaper.fm/download.php",
            "base_url": "https://www.reaper.fm/",
            "match": {
              "contains": [
                "-install.exe"
              ],
              "not_contains": [
                "_x64",
                "arm64ec"
              ],
              "ends_with": "-install.exe"
            }
          }
        }
      },
      {
        "platform": "windows",
        "match_arches": [
          "x64",
          "universal",
          "unknown"
        ],
        "report_arch": "x64",
        "artifact_kind": "installer",
        "source": {
          "scrape_href": {
            "page_url": "https://www.reaper.fm/download.php",
            "base_url": "https://www.reaper.fm/",
            "match": {
              "contains": [
                "_x64-install.exe"
              ],
              "ends_with": "-install.exe"
            }
          }
        }
      },
      {
        "platform": "windows",
        "match_arches": [
          "arm64",
          "arm64-ec"
        ],
        "report_arch": "arm64-ec",
        "artifact_kind": "installer",
        "source": {
          "scrape_href": {
            "page_url": "https://www.reaper.fm/download.php",
            "base_url": "https://www.reaper.fm/",
            "match": {
              "contains": [
                "arm64ec"
              ],
              "ends_with": "-install.exe"
            }
          }
        }
      },
      {
        "platform": "macos",
        "match_arches": [
          "x86"
        ],
        "report_arch": "x86",
        "artifact_kind": "disk_image",
        "source": {
          "scrape_href": {
            "page_url": "https://www.reaper.fm/download.php",
            "base_url": "https://www.reaper.fm/",
            "match": {
              "contains": [
                "_i386.dmg"
              ],
              "ends_with": "_i386.dmg"
            }
          }
        }
      },
      {
        "platform": "macos",
        "match_arches": [
          "x64",
          "arm64",
          "arm64-ec",
          "universal",
          "unknown"
        ],
        "report_arch": "universal",
        "artifact_kind": "disk_image",
        "source": {
          "scrape_href": {
            "page_url": "https://www.reaper.fm/download.php",
            "base_url": "https://www.reaper.fm/",
            "match": {
              "contains": [
                "_universal.dmg"
              ],
              "ends_with": "_universal.dmg"
            }
          }
        }
      }
    ]
  }
}
