{
  "id": "reakontrol",
  "display_name": "ReaKontrol",
  "display_name_key": "package-reakontrol",
  "display_description_key": "package-reakontrol-description",
  "package_kind": "user_plugin_binary",
  "required": false,
  "recommended": false,
  "recommended_when": "komplete_kontrol_installed",
  "supported_platforms": [
    "windows",
    "macos"
  ],
  "supported_architectures": [
    "x86",
    "x64",
    "arm64",
    "arm64-ec",
    "universal"
  ],
  "github_release": {
    "repo": "jcsteh/reaKontrol",
    "release": "latest",
    "version_from": {
      "asset_name": {
        "strip_trailing_dot_segment": true
      }
    },
    "assets": [
      {
        "platform": "windows",
        "name_prefix": "reaKontrol_windows_",
        "name_suffix": ".zip"
      },
      {
        "platform": "macos",
        "name_prefix": "reaKontrol_mac_",
        "name_suffix": ".zip"
      }
    ],
    "artifact_kind": "archive",
    "install_destination": "user_plugins"
  },
  "detectors": [
    "rabbit_receipt",
    "user_plugin_file"
  ],
  "install_steps": [
    "copy_user_plugin_binary"
  ],
  "uninstall_steps": [
    "remove_user_plugin_binary"
  ],
  "backup_policy": "backup_overwritten_files",
  "user_plugin_prefixes": [
    "reaper_kontrol"
  ],
  "user_plugin_suffixes": {
    "windows": [
      ".dll"
    ],
    "macos": [
      ".dylib"
    ]
  }
}
