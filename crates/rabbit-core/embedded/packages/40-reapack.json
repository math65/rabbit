{
  "id": "reapack",
  "display_name": "ReaPack",
  "display_name_key": "package-reapack",
  "display_description_key": "package-reapack-description",
  "package_kind": "user_plugin_binary",
  "required": false,
  "recommended": false,
  "requires_user_acknowledgement": true,
  "supported_platforms": [
    "windows",
    "macos"
  ],
  "supported_architectures": [
    "x86",
    "x64",
    "arm64",
    "arm64-ec",
    "universal"
  ],
  "github_release": {
    "repo": "cfillion/reapack",
    "release": "latest",
    "version_from": {
      "tag_name": {
        "strip_v_prefix": true
      }
    },
    "assets": [
      {
        "platform": "windows",
        "arch": "x86",
        "exact_name": "reaper_reapack-x86.dll"
      },
      {
        "platform": "windows",
        "arch": "x64",
        "exact_name": "reaper_reapack-x64.dll"
      },
      {
        "platform": "windows",
        "arch": "arm64",
        "exact_name": "reaper_reapack-arm64ec.dll"
      },
      {
        "platform": "windows",
        "arch": "arm64-ec",
        "exact_name": "reaper_reapack-arm64ec.dll"
      },
      {
        "platform": "macos",
        "arch": "x86",
        "exact_name": "reaper_reapack-i386.dylib"
      },
      {
        "platform": "macos",
        "arch": "x64",
        "exact_name": "reaper_reapack-x86_64.dylib"
      },
      {
        "platform": "macos",
        "arch": "arm64",
        "exact_name": "reaper_reapack-arm64.dylib"
      }
    ],
    "artifact_kind": "extension_binary",
    "install_destination": "user_plugins"
  },
  "detectors": [
    "rabbit_receipt",
    "user_plugin_file",
    "file_version_metadata",
    "reapack_registry"
  ],
  "install_steps": [
    "copy_user_plugin_binary"
  ],
  "uninstall_steps": [
    "remove_user_plugin_binary"
  ],
  "backup_policy": "backup_overwritten_files",
  "user_plugin_prefixes": [
    "reaper_reapack"
  ],
  "user_plugin_suffixes": {
    "windows": [
      ".dll"
    ],
    "macos": [
      ".dylib"
    ]
  }
}
