{
  "id": "ffmpeg",
  "display_name": "FFmpeg",
  "display_name_key": "package-ffmpeg",
  "display_description_key": "package-ffmpeg-description",
  "package_kind": "user_plugin_binary",
  "required": false,
  "recommended": false,
  "supported_platforms": [
    "windows"
  ],
  "supported_architectures": [
    "x64",
    "arm64",
    "arm64-ec"
  ],
  "version": {
    "plain_text": {
      "url": "https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-full-shared.7z.ver"
    }
  },
  "detectors": [
    "rabbit_receipt",
    "user_plugin_file",
    "ffmpeg_libavformat"
  ],
  "install_steps": [
    "copy_user_plugin_binary"
  ],
  "uninstall_steps": [
    "remove_user_plugin_binary"
  ],
  "backup_policy": "backup_overwritten_files",
  "user_plugin_prefixes": [
    "avformat",
    "avcodec",
    "avdevice",
    "avfilter",
    "avutil",
    "swresample",
    "swscale",
    "postproc"
  ],
  "user_plugin_suffixes": {
    "windows": [
      ".dll"
    ],
    "macos": [
      ".dylib"
    ]
  },
  "http_artifact": {
    "targets": [
      {
        "platform": "windows",
        "match_arches": [
          "x64",
          "universal",
          "unknown"
        ],
        "report_arch": "x64",
        "artifact_kind": "seven_zip_archive",
        "source": {
          "fixed_url": {
            "url": "https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-full-shared.7z",
            "file_name": "ffmpeg-release-full-shared.7z"
          }
        }
      },
      {
        "platform": "windows",
        "match_arches": [
          "arm64",
          "arm64-ec"
        ],
        "report_arch": "arm64",
        "artifact_kind": "seven_zip_archive",
        "source": {
          "github_release_max_major": {
            "repo": "tordona/ffmpeg-win-arm64",
            "supported_major": 8,
            "asset": {
              "contains": [
                "-full-shared-win-arm64"
              ],
              "ends_with": ".7z"
            }
          }
        }
      }
    ]
  }
}
